# DriveX Rental Car — Variables de entorno
# Copiar a .env (Docker Compose lo lee automáticamente) o exportar en la sesión.
# Estos valores son de DEMO para desarrollo local; en producción usar valores seguros.

# Base de datos PostgreSQL
DB_NAME=drivex_db
DB_USER=drivex_user
DB_PASSWORD=1234
DB_HOST=localhost
DB_PORT=5432

# Django
DJANGO_SECRET_KEY=django-insecure-demo-key-solo-para-desarrollo-local
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
